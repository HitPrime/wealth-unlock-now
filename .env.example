# .env.example
# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit it.
# If a real value lands in a commit by accident, rotate it immediately.

# Public values (safe to ship to the browser, framework-prefixed)
# VITE_API_URL=
# NEXT_PUBLIC_API_URL=

# Server-only secrets (NEVER expose to the browser, NEVER prefix with VITE_/NEXT_PUBLIC_)
# DATABASE_URL=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# GoHighLevel (LeadConnector) — tags free Trading Starter Kit leads via GHL's REST API.
# Private Integration Token: GHL → Settings → Private Integrations (needs the contacts.write scope).
GHL_MCP_PIT=
# The sub-account / location ID leads should land in.
GHL_MCP_LOCATION_ID=
